<% if notice.present? || alert.present? %>
  <div class="mx-auto max-w-5xl px-4 pt-4">
    <% if notice.present? %>
      <p class="mb-2 rounded-lg border border-[#E6F4EA] bg-[#E6F4EA] px-4 py-2 text-sm text-[#1A7F37]"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="mb-2 rounded-lg border border-[#FECACA] bg-[#FEF2F2] px-4 py-2 text-sm text-[#DC2626]"><%= alert %></p>
    <% end %>
  </div>
<% end %>
