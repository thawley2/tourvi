<% content_for :title, "Edit Profile" %>
<div class="mx-auto max-w-2xl px-4 py-8">
  <h1 class="mb-5 font-display text-2xl">Edit Profile</h1>

  <%= form_with model: @agent, url: profile_path, method: :patch, class: "tv-card p-6" do |f| %>
    <% if @agent.errors.any? %>
      <div class="mb-4 rounded-lg border border-[#FECACA] bg-[#FEF2F2] px-4 py-3 text-sm text-[#DC2626]">
        <%= @agent.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="mb-5 flex items-center gap-4">
      <%= agent_avatar @agent, size: :lg %>
      <div>
        <%= f.label :avatar, "Profile photo", class: "tv-label" %>
        <%= f.file_field :avatar, accept: "image/*", class: "text-sm" %>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= f.label :name, "Full name", class: "tv-label" %>
        <%= f.text_field :name, class: "tv-input" %>
      </div>
      <div>
        <%= f.label :title, class: "tv-label" %>
        <%= f.text_field :title, class: "tv-input", placeholder: "Realtor" %>
      </div>
      <div>
        <%= f.label :phone, class: "tv-label" %>
        <%= f.telephone_field :phone, class: "tv-input" %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :brokerage, class: "tv-label" %>
        <%= f.text_field :brokerage, class: "tv-input" %>
      </div>
      <div>
        <%= f.label :license_number, "License number", class: "tv-label" %>
        <%= f.text_field :license_number, class: "tv-input" %>
      </div>
      <div>
        <span class="tv-label">Profile color</span>
        <div class="flex gap-2">
          <% %w[#C9A96E #7B9E87 #8B7BAE #C97B6E #6E8EC9 #1A1A18].each do |color| %>
            <label class="cursor-pointer">
              <%= f.radio_button :profile_color, color, class: "peer sr-only" %>
              <span class="block h-7 w-7 rounded-full ring-2 ring-offset-2 ring-transparent peer-checked:ring-ink bg-[<%= color %>]"></span>
            </label>
          <% end %>
        </div>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :bio, class: "tv-label" %>
        <%= f.text_area :bio, rows: 4, class: "tv-input" %>
      </div>
    </div>

    <div class="mt-5 flex gap-2">
      <%= f.submit "Save Profile", class: "tv-btn-dark" %>
      <%= link_to "Cancel", profile_path, class: "tv-btn-light" %>
    </div>
  <% end %>
</div>
