<%# Pass `property`, `tour`, `index`. %>
<%= turbo_frame_tag dom_id(property), class: "block", data: { id: property.id } do %>
  <div class="tv-card flex gap-3 p-4">
    <div class="drag-handle flex h-6 w-6 shrink-0 cursor-grab items-center justify-center rounded-full bg-gold text-[11px] font-bold text-[#3D2B0A]">
      <%= index + 1 %>
    </div>
    <div class="flex-1">
      <div class="flex items-start justify-between gap-2">
        <div>
          <div class="font-semibold"><%= property.address %></div>
          <div class="text-xs text-muted"><%= property.city %></div>
        </div>
        <%= button_to "Remove", tour_property_path(tour, property), method: :delete,
              class: "tv-btn-danger !px-2 !py-1 !text-xs",
              form: { data: { turbo_confirm: "Remove this stop?" } } %>
      </div>
      <div class="mt-2 flex flex-wrap items-center gap-1.5">
        <% if property.beds %><span class="tv-chip"><%= property.beds %> bd</span><% end %>
        <% if property.baths %><span class="tv-chip"><%= property.baths %> ba</span><% end %>
        <% if property.price.present? %><span class="text-sm font-bold text-gold-deep"><%= property.price %></span><% end %>
        <% if property.mls_id.present? %><span class="tv-chip"><%= property.mls_id %></span><% end %>
      </div>

      <% if property.notes.present? %>
        <div class="mt-2 rounded-lg border-l-[3px] border-gold bg-[#F8F7FC] px-3 py-2 text-xs leading-relaxed text-[#555555]">
          <span class="mb-0.5 block text-[10px] font-bold text-muted">AGENT NOTE</span>
          <%= property.notes %>
        </div>
      <% end %>

      <%= link_to (property.notes.present? ? "Edit note" : "+ Add note"),
            edit_tour_property_path(tour, property),
            class: "mt-2 inline-block text-xs font-semibold text-gold-deep" %>
    </div>
  </div>
<% end %>
