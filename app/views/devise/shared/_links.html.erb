<div class="mt-5 space-y-1.5 text-center text-sm text-muted">
  <%- if controller_name != 'sessions' %>
    <div><%= link_to "Log in", new_session_path(resource_name), class: "text-gold-deep hover:underline" %></div>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div><%= link_to "Create an account", new_registration_path(resource_name), class: "text-gold-deep hover:underline" %></div>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <div><%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-gold-deep hover:underline" %></div>
  <% end %>
</div>
