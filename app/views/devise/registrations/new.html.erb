<% content_for :title, "Create account" %>
<div class="flex min-h-screen flex-col items-center justify-center px-5 py-10">
  <div class="mb-9 flex items-center gap-2.5">
    <span class="flex h-9 w-9 items-center justify-center rounded-[9px] bg-ink">
      <svg width="18" height="18" viewBox="0 0 14 14" fill="none"><path d="M7 1L2 5.5V13h3.5V9h3v4H12V5.5L7 1Z" fill="#C9A96E"/></svg>
    </span>
    <span class="font-display text-[28px] font-medium tracking-tight">tourvi</span>
  </div>

  <div class="w-full max-w-md rounded-2xl border border-line bg-white p-8 shadow-sm">
    <h1 class="font-display text-xl">Create your account</h1>
    <p class="mb-6 mt-1 text-sm text-muted">Start managing your tours in minutes</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-3.5">
        <%= f.label :name, "Full name", class: "tv-label" %>
        <%= f.text_field :name, autofocus: true, class: "tv-input", placeholder: "Jane Smith" %>
      </div>
      <div class="mb-3.5">
        <%= f.label :email, class: "tv-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "tv-input", placeholder: "you@brokerage.com" %>
      </div>
      <div class="mb-3.5">
        <%= f.label :password, class: "tv-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "tv-input", placeholder: "••••••••" %>
        <% if @minimum_password_length %>
          <p class="mt-1 text-xs text-muted"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
      </div>
      <div class="mb-4">
        <%= f.label :password_confirmation, "Confirm password", class: "tv-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "tv-input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Create account", class: "tv-btn-dark w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
