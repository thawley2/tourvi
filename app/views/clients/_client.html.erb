<%= link_to client, id: dom_id(client), class: "tv-card block p-4 transition hover:border-gold-soft" do %>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-3">
      <%= avatar client.name, idx: client.id %>
      <div>
        <div class="font-semibold"><%= client.name %></div>
        <div class="text-xs text-muted"><%= client.budget.presence || "No budget set" %></div>
      </div>
    </div>
    <%= stage_badge client.stage %>
  </div>
  <% if client.notes.present? %>
    <p class="mt-3 line-clamp-2 text-sm text-[#555555]"><%= client.notes %></p>
  <% end %>
<% end %>
